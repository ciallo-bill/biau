# Blog draft model channels. Keep real relay URLs and API keys in .env.local.
# Prefer `npm run blog:model -- setup` for the guided three-profile wizard.
# Temperature is advanced/optional; defaults are shown only for reference.
# Default channel used as a shared fallback by `npm run blog:draft -- --generate`.
BLOG_DRAFT_BASE_URL=
BLOG_DRAFT_API_KEY=
BLOG_DRAFT_MODEL=
BLOG_DRAFT_PROVIDER=
BLOG_DRAFT_TEMPERATURE=0.65

# Generation profile selected with `--profile strong` or BLOG_DRAFT_PROFILE=strong.
# Recommended model: GLM-5.2 or Gemini 3.1 Pro.
BLOG_DRAFT_STRONG_BASE_URL=
BLOG_DRAFT_STRONG_API_KEY=
BLOG_DRAFT_STRONG_MODEL=glm-5.2-or-gemini-3.1-pro
BLOG_DRAFT_STRONG_PROVIDER=generation-relay
BLOG_DRAFT_STRONG_TEMPERATURE=0.65

# Fast helper profile for outlines, titles, summaries, and low-risk checks.
# Recommended model: Gemini 3.5 Flash.
BLOG_DRAFT_FAST_BASE_URL=
BLOG_DRAFT_FAST_API_KEY=
BLOG_DRAFT_FAST_MODEL=gemini-3.5-flash
BLOG_DRAFT_FAST_PROVIDER=fast-relay
BLOG_DRAFT_FAST_TEMPERATURE=0.35

# Polishing profile selected with `--profile review` or BLOG_DRAFT_PROFILE=review.
# Recommended model: DeepSeek V4 Pro.
BLOG_DRAFT_REVIEW_BASE_URL=
BLOG_DRAFT_REVIEW_API_KEY=
BLOG_DRAFT_REVIEW_MODEL=deepseek-v4-pro
BLOG_DRAFT_REVIEW_PROVIDER=polish-relay
BLOG_DRAFT_REVIEW_TEMPERATURE=0.2

# Legacy fallback for older blog draft scripts/configs.
GEMINI_BASE_URL=http://localhost:8317
GEMINI_API_KEY=
GEMINI_MODEL=gemini
GEMINI_TEMPERATURE=0.65
VITE_OZON_ERP_URL=https://erp.ciallobill.qzz.io
# Public assistant frontend API base. Use /api for Cloudflare Pages Functions,
# or http://localhost:8787 / Render URL for the standalone Express API. The
# browser calls this server only; never expose model API keys through Vite vars.
VITE_CHAT_API_BASE_URL=/api

# Optional visitor analytics adapter. Leave empty to disable all event tracking.
# Supported values: umami, plausible, debug.
# Real site IDs, script URLs, or provider tokens should be configured in the
# analytics provider / Cloudflare Pages environment, not committed here.
VITE_ANALYTICS_PROVIDER=

PORT=8787
METRICS_ENABLED=false
DATABASE_URL=
CORS_ORIGIN=http://localhost:5173
ADMIN_TOKEN=change-me

# Public/internal assistant model provider. Prefer these variables for the
# assistant API model channel. Keep real relay URLs and API keys in deployment
# env or .env.local; `/chat/public` falls back to public knowledge if unset or
# if the provider fails. Do not put model keys in Vite variables.
# Recommended public assistant channel: GLM-5.2 through an OpenAI-compatible
# relay. Prefer an explicit /v1 base URL; the server also accepts a full
# /chat/completions endpoint. Keep the actual relay URL/key private.
ASSISTANT_MODEL_BASE_URL=https://relay.example.com/v1
ASSISTANT_MODEL_API_KEY=
ASSISTANT_MODEL_NAME=glm-5.2
ASSISTANT_MODEL_PROVIDER=glm-compatible

# Legacy compatibility: existing deployments that still use OPENAI_* continue
# to work, but new deployments should use ASSISTANT_MODEL_* above.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
