# Blog draft model channels. Keep real relay URLs and API keys in .env.local.
# Prefer `npm run blog:model -- setup` for the guided three-profile wizard.
# Temperature is advanced/optional; defaults are shown only for reference.
# Optional request timeout for long draft/review calls, in milliseconds.
BLOG_DRAFT_REQUEST_TIMEOUT_MS=300000
# Long draft polishing defaults to section-level calls to avoid relay timeouts.
# Set to full only when you intentionally want one monolithic review call.
BLOG_DRAFT_POLISH_MODE=sections

# Default channel used as a shared fallback by `npm run blog:draft -- --generate`.
BLOG_DRAFT_BASE_URL=
BLOG_DRAFT_API_KEY=
BLOG_DRAFT_MODEL=
BLOG_DRAFT_PROVIDER=
BLOG_DRAFT_TEMPERATURE=0.65

# Generation profile selected with `--profile strong` or BLOG_DRAFT_PROFILE=strong.
# Recommended model: GLM-5.2 or Gemini 3.1 Pro.
BLOG_DRAFT_STRONG_BASE_URL=
BLOG_DRAFT_STRONG_API_KEY=
BLOG_DRAFT_STRONG_MODEL=glm-5.2-or-gemini-3.1-pro
BLOG_DRAFT_STRONG_PROVIDER=generation-relay
BLOG_DRAFT_STRONG_TEMPERATURE=0.65

# Optional same-profile fallback channels. Configure through
# `npm run blog:model -- setup --profile strong --fallback` when possible.
BLOG_DRAFT_STRONG_FALLBACK_1_BASE_URL=
BLOG_DRAFT_STRONG_FALLBACK_1_API_KEY=
BLOG_DRAFT_STRONG_FALLBACK_1_MODEL=glm-5.2-or-gemini-3.1-pro
BLOG_DRAFT_STRONG_FALLBACK_1_PROVIDER=generation-relay-backup
BLOG_DRAFT_STRONG_FALLBACK_1_TEMPERATURE=0.65

# Fast helper profile for outlines, titles, summaries, and low-risk checks.
# Recommended model: Gemini 3.5 Flash.
BLOG_DRAFT_FAST_BASE_URL=
BLOG_DRAFT_FAST_API_KEY=
BLOG_DRAFT_FAST_MODEL=gemini-3.5-flash
BLOG_DRAFT_FAST_PROVIDER=fast-relay
BLOG_DRAFT_FAST_TEMPERATURE=0.35

BLOG_DRAFT_FAST_FALLBACK_1_BASE_URL=
BLOG_DRAFT_FAST_FALLBACK_1_API_KEY=
BLOG_DRAFT_FAST_FALLBACK_1_MODEL=gemini-3.5-flash
BLOG_DRAFT_FAST_FALLBACK_1_PROVIDER=fast-relay-backup
BLOG_DRAFT_FAST_FALLBACK_1_TEMPERATURE=0.35

# Polishing profile selected with `--profile review` or BLOG_DRAFT_PROFILE=review.
# Recommended model: DeepSeek V4 Pro.
BLOG_DRAFT_REVIEW_BASE_URL=
BLOG_DRAFT_REVIEW_API_KEY=
BLOG_DRAFT_REVIEW_MODEL=deepseek-v4-pro
BLOG_DRAFT_REVIEW_PROVIDER=polish-relay
BLOG_DRAFT_REVIEW_TEMPERATURE=0.2

BLOG_DRAFT_REVIEW_FALLBACK_1_BASE_URL=
BLOG_DRAFT_REVIEW_FALLBACK_1_API_KEY=
BLOG_DRAFT_REVIEW_FALLBACK_1_MODEL=deepseek-v4-pro
BLOG_DRAFT_REVIEW_FALLBACK_1_PROVIDER=polish-relay-backup
BLOG_DRAFT_REVIEW_FALLBACK_1_TEMPERATURE=0.2

# Legacy fallback for older blog draft scripts/configs.
GEMINI_BASE_URL=http://localhost:8317
GEMINI_API_KEY=
GEMINI_MODEL=gemini
GEMINI_TEMPERATURE=0.65
VITE_OZON_ERP_URL=https://erp.ciallobill.qzz.io
# Public assistant frontend API base. Use /api for Cloudflare Pages Functions,
# or http://localhost:8787 / Render URL for the standalone Express API. The
# browser calls this server only; never expose model API keys through Vite vars.
VITE_CHAT_API_BASE_URL=/api
# Optional Content Studio API base. Defaults to VITE_INTERNAL_ASSISTANT_API_BASE_URL
# or VITE_CHAT_API_BASE_URL when unset. This is only the backend URL, not a secret.
VITE_STUDIO_API_BASE_URL=
# Optional server-side/local export API base for `npm run studio:export`.
# If empty, the exporter can reuse VITE_STUDIO_API_BASE_URL. This is not a
# secret, but keep tokens in STUDIO_ADMIN_TOKEN / ADMIN_TOKEN.
STUDIO_EXPORT_API_BASE=

# Optional visitor analytics adapter. Leave empty to disable all event tracking.
# Supported values: umami, plausible, debug.
# Real site IDs, script URLs, or provider tokens should be configured in the
# analytics provider / Cloudflare Pages environment, not committed here.
VITE_ANALYTICS_PROVIDER=

PORT=8787
METRICS_ENABLED=false
DATABASE_URL=
# Optional dedicated Content Studio database. When set, /studio/api uses this
# Postgres database instead of DATABASE_URL, so assistant data and content drafts
# can be maintained separately.
STUDIO_DATABASE_URL=
CORS_ORIGIN=http://localhost:5173
ADMIN_TOKEN=change-me
# Optional owner-only Content Studio token. If empty, the backend falls back to
# ADMIN_TOKEN. Keep the real value in deployment env or .env.local.
STUDIO_ADMIN_TOKEN=
# Backend runtime boundary. Local development can leave this empty (`all`).
# Render final deployment should create three Web Services with explicit modes:
# public, internal, and rag.
ASSISTANT_SERVICE_MODE=all

# Public/internal assistant model provider. Prefer these variables for the
# assistant API model channel. Keep real relay URLs and API keys in deployment
# env or .env.local; `/chat/public` falls back to public knowledge if unset or
# if the provider fails. Do not put model keys in Vite variables.
# Recommended public assistant channel: GLM-5.2 through an OpenAI-compatible
# relay. Prefer an explicit /v1 base URL; the server also accepts a full
# /chat/completions endpoint. Keep the actual relay URL/key private.
ASSISTANT_MODEL_BASE_URL=https://relay.example.com/v1
ASSISTANT_MODEL_API_KEY=
ASSISTANT_MODEL_NAME=glm-5.2
ASSISTANT_MODEL_PROVIDER=glm-compatible
# Optional internal-assistant member model channels. The API key/baseUrl values
# are server-only. Members store only `modelChannelId`; admin/member APIs return
# sanitized id/label/provider/model/configured fields.
# Example shape:
# ASSISTANT_MODEL_CHANNELS_JSON=[{"id":"mimo","label":"Mimo member channel","provider":"mimo-compatible","baseUrl":"https://relay.example.com/v1","apiKey":"replace-in-deployment-env","model":"mimo-chat"},{"id":"deepseek","label":"DeepSeek review channel","provider":"deepseek-compatible","baseUrl":"https://relay.example.com/v1","apiKey":"replace-in-deployment-env","model":"deepseek-ai/deepseek-v4-pro"}]
ASSISTANT_MODEL_CHANNELS_JSON=

# Optional server-side public/internal assistant RAG Orchestrator contract.
# Final deployment uses a separate ASSISTANT_SERVICE_MODE=rag service backed by
# Qdrant collections. Public/internal assistant services call only this
# Orchestrator endpoint and must not connect to Qdrant directly. Never expose
# these values through Vite variables.
ASSISTANT_RAG_API_BASE_URL=
ASSISTANT_RAG_API_KEY=
ASSISTANT_RAG_TIMEOUT_MS=3000

# Standalone RAG Orchestrator. These are server-only Render variables for
# ASSISTANT_SERVICE_MODE=rag. Keep real database/vector URLs and tokens private.
# In production set RAG_STORE_PROVIDER=qdrant and fill QDRANT_* plus embedding
# values. Local development can keep RAG_STORE_PROVIDER=local.
# Internal Assistant API also needs the same RAG_SYNC_TOKEN when the admin
# Knowledge area should submit REVIEWED/ACTIVE internal documents to the
# Orchestrator. Leave empty for local-only skipped sync plans.
RAG_STORE_PROVIDER=local
# Compatibility/future-management placeholders only. The agreed production
# vector path is Qdrant; public/internal assistant services should not set or
# consume these directly.
RAG_DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Qdrant production store for the standalone RAG Orchestrator.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PUBLIC_COLLECTION=biau_public_chunks
QDRANT_INTERNAL_COLLECTION=biau_internal_chunks
RAG_PUBLIC_API_KEY=
RAG_INTERNAL_API_KEY=
RAG_SYNC_TOKEN=

# Optional OpenAI-compatible embedding/reranker channels for external RAG sync
# and retrieval. Leave empty to use deterministic local embeddings for local
# tests. Qdrant production collections are configured for qwen3-embedding-8b
# with 4096 dimensions.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=deterministic-local
EMBEDDING_DIMENSION=4096
EMBEDDING_TIMEOUT_MS=20000
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=

# Legacy compatibility: existing deployments that still use OPENAI_* continue
# to work, but new deployments should use ASSISTANT_MODEL_* above.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
