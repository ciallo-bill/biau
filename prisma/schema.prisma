generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Invite {
  id         String    @id @default(cuid())
  codeHash   String    @unique
  label      String
  role       MemberRole @default(MEMBER)
  dailyQuota Int       @default(24)
  maxUses    Int       @default(1)
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  members    Member[]
}

model Member {
  id             String       @id @default(cuid())
  name           String
  role           MemberRole   @default(MEMBER)
  status         MemberStatus @default(ACTIVE)
  tokenHash      String       @unique
  dailyQuota     Int          @default(24)
  modelChannelId String?
  disabledAt     DateTime?
  lastSeenAt     DateTime?
  inviteId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  invite         Invite?      @relation(fields: [inviteId], references: [id])
  sessions       ChatSession[]
  messages       ChatMessage[]
  usageLogs      UsageLog[]
}

model ChatSession {
  id            String        @id @default(cuid())
  memberId      String
  title         String
  archivedAt    DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  memberId  String?
  sessionId String?
  role      MessageRole
  content   String
  citations Json?
  createdAt DateTime    @default(now())
  member    Member?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  session   ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id        String   @id @default(cuid())
  memberId  String?
  scope     String
  model     String?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  createdAt DateTime @default(now())
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model ContentDraft {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  column          String
  tag             String
  detail          String
  readTime        String             @default("8 min")
  bodyJson        Json
  knowledgePoints Json?
  projectIds      Json?
  status          ContentDraftStatus @default(DRAFT)
  visibility      ContentVisibility  @default(HIDDEN)
  aiAssistance    String             @default("none")
  createdBy       String?
  updatedBy       String?
  publishedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  reviews         ContentReview[]
  publishExports  PublishExport[]
  aiDailyIssues   AiDailyIssue[]
}

model ContentReview {
  id            String              @id @default(cuid())
  draftId       String
  status        ContentReviewStatus @default(PENDING)
  checklistJson Json
  notes         String              @default("")
  reviewedBy    String?
  reviewedAt    DateTime            @default(now())
  draft         ContentDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model PublishExport {
  id                String       @id @default(cuid())
  draftId           String
  target            String
  exportedFilesJson Json
  checksJson        Json?
  exportedBy        String?
  createdAt         DateTime     @default(now())
  draft             ContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model SourceItem {
  id            String   @id @default(cuid())
  title         String
  url           String
  sourceName    String
  sourceTier    String
  language      String   @default("zh")
  publishedAt   DateTime?
  capturedAt    DateTime @default(now())
  rawExcerpt    String?
  summary       String   @default("")
  tagsJson      Json?
  riskFlagsJson Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiDailyIssue {
  id            String             @id @default(cuid())
  date          String             @unique
  title         String
  status        AiDailyIssueStatus @default(SOURCE_COLLECTED)
  sourceIdsJson Json
  briefJson     Json?
  draftId       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  draft         ContentDraft?      @relation(fields: [draftId], references: [id], onDelete: SetNull)
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum MemberStatus {
  ACTIVE
  DISABLED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ContentDraftStatus {
  DRAFT
  REVIEW_NEEDED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ContentVisibility {
  HIDDEN
  FEATURED
  ARCHIVE
}

enum ContentReviewStatus {
  PENDING
  APPROVED
  NEEDS_CHANGES
  REJECTED
}

enum AiDailyIssueStatus {
  SOURCE_COLLECTED
  EXTRACTED
  SUMMARIZED
  SYNTHESIZED
  REVIEW_NEEDED
  APPROVED
  PUBLISHED
  REJECTED
  NEEDS_MORE_EVIDENCE
}
