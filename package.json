{
  "name": "blog-semi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "assistant:index": "tsx scripts/generate-assistant-knowledge.ts",
    "server:dev": "tsx watch server/src/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/index.js",
    "server:smoke": "tsx server/scripts/smoke.ts",
    "cf-assistant:smoke": "tsx scripts/check-cloudflare-assistant-functions.mjs",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "blog:plan": "node scripts/generate-blog-draft.mjs --list",
    "blog:draft": "node scripts/generate-blog-draft.mjs",
    "blog:model": "node scripts/configure-blog-model.mjs",
    "blog:model:wizard": "node scripts/configure-blog-model.mjs setup",
    "blog:model:check": "node scripts/configure-blog-model.mjs doctor",
    "blog:audit": "tsx scripts/audit-blog-catalog.ts",
    "blog:check": "node scripts/check-public-blog.mjs",
    "docs:observability-check": "node scripts/check-observability-docs.mjs",
    "erp:synthetic": "node scripts/check-erp-synthetic.mjs",
    "legal-rag:synthetic": "node scripts/check-legal-rag-synthetic.mjs",
    "main-site:synthetic": "node scripts/check-main-site-synthetic.mjs",
    "pet:synthetic": "node scripts/check-pet-showcase-synthetic.mjs",
    "site:monitor": "node scripts/check-site-monitor.mjs",
    "site:status": "tsx scripts/generate-site-status.ts",
    "xunqiu:synthetic": "node scripts/check-xunqiu-synthetic.mjs",
    "preview": "vite preview",
    "check:ui": "tsx scripts/check-ui.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "sitemap:generate": "tsx scripts/generate-sitemap.mjs",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.100.0",
    "@douyinfe/semi-ui-19": "^2.100.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prisma": "^7.8.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
